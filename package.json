    "@types/node": "20.19.0",
    "autoprefixer": "^10.4.27",
    "eslint": "9.32.0",
    "eslint-plugin-qwik": "^1.19.2",
    "globals": "16.4.0",
    "postcss": "^8.5.8",
    "prettier": "3.6.2",
    "tailwindcss": "^4.2.1",
    "typescript": "5.4.5",
    "typescript-eslint": "8.38.0",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^4.2.1"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
