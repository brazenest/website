{
  "name": "personal-site-v3",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "scripts": {
    "dev": "vite --mode ssr",
    "start": "vite --mode ssr",
    "build": "qwik build",
