{
  "name": "@brazenest/website",
  "version": "3.0.0",
  "description": "Personal site v3 Qwik workspace rooted in src/ with next-app/ preserved as legacy reference code.",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build --config vite.config.ts",
    "build.preview": "vite build --config vite.config.ts --ssr src/entry.preview.tsx",
    "build.types": "tsc -p tsconfig.json --incremental --noEmit",
    "dev": "vite --config vite.config.ts --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --config vite.config.ts --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"vite.config.ts\" \"eslint.config.mjs\"",
    "preview": "qwik build preview && vite preview",
    "start": "vite --config vite.config.ts --mode ssr",
    "qwik": "qwik"
  },
  "repository": "https://github.com/brazenest/website",
  "author": "Alden Gillespy <61519345+brazenest@users.noreply.github.com>",
  "license": "SCEL-1.2",
  "devDependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@eslint/js": "^9.32.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "20.19.0",
    "eslint": "9.32.0",
    "eslint-plugin-qwik": "^1.19.2",
    "globals": "16.4.0",
    "prettier": "3.6.2",
    "tailwindcss": "^4.1.17",
    "typescript": "5.4.5",
    "typescript-eslint": "8.38.0",
    "undici": "*",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^4.2.1"
  }
}
