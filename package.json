{
  "name": "personal-site-v3",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "node scripts/with-env.mjs .env.production -- qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vite build -c adapters/fastify/vite.config.ts",
    "build.cloudflare": "npm run build.cloudflare.client && npm run build.cloudflare.server",
    "build.cloudflare.client": "node scripts/with-env.mjs .env.production -- vite build",
    "build.cloudflare.server": "node scripts/with-env.mjs .env.production -- vite build -c adapters/cloudflare-pages/vite.config.ts && node scripts/fix-cloudflare-worker.mjs",
    "deploy.cloudflare": "wrangler pages deploy dist",
    "preview.cloudflare": "wrangler pages dev dist",
    "build.types": "tsc --noEmit",
    "dev": "node scripts/with-env.mjs .env.development -- vite --mode ssr",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "generate:case-study-images": "node scripts/generate-case-study-images.mjs",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview",
    "serve": "node scripts/serve-built.mjs",
    "serve:production": "node scripts/with-env.mjs .env.production -- node scripts/serve-built.mjs",
    "start": "node scripts/with-env.mjs .env.development -- vite --mode ssr",
    "test:visual": "node scripts/visual-smoke.mjs",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@eslint/js": "^9",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "20.19.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.3.2",
    "eslint": "9.32.0",
    "eslint-plugin-qwik": "^1.19.2",
    "globals": "16.4.0",
    "postcss": "^8.5.8",
    "prettier": "3.6.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "5.4.5",
    "typescript-eslint": "8.38.0",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^4.2.1",
    "wrangler": "^4.42.0"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/static": "^9.1.3",
    "@fontsource-variable/inter": "^5.2.8",
    "clsx": "^2.1.1",
    "fastify": "^5.7.3",
    "fastify-plugin": "^4.5.0",
    "pg": "^8.21.0",
    "tailwind-merge": "^3.5.0",
    "undici": "^6.25.0"
  },
  "pnpm": {
    "overrides": {
      "undici": "6.25.0"
    }
  }
}
