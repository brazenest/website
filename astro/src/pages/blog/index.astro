---
/**
 * BLOG INDEX (BUILD.md §7 — deferred design pass). Minimal list of all posts.
 * Renders in the house/neutral identity.
 */
import Base from '../../layouts/Base.astro'
import { posts } from '../../lib/content'

const sorted = [...posts]
  .filter((p) => p.publishedAt)
  .sort((a, b) => new Date(b.publishedAt!).getTime() - new Date(a.publishedAt!).getTime())
---

<Base title="Blog — Alden Gillespy" zone="neutral" work="house">
  <section class="z-neutral" data-zone="neutral" data-work="house">
    <div class="col">
      <div class="crumb"><span>Blog</span></div>
      <article style="margin-block: clamp(30px, 3.4vw, 56px);">
        <h1 class="halo">Writing</h1>
        {
          sorted.length > 0 ? (
            <div class="post__list" style="margin-top: clamp(30px, 3.4vw, 56px);">
              {sorted.map((post) => (
                <article class="post__item" style="margin-bottom: clamp(30px, 3.4vw, 56px); padding-bottom: clamp(30px, 3.4vw, 56px); border-bottom: 1px solid var(--line);">
                  <a href={`/blog/${post.slug}`} style="text-decoration: none;">
                    <h3 class="halo" style="margin-bottom: 12px;">{post.title}</h3>
                  </a>
                  <div style="font-size: 13px; color: var(--muted); margin-bottom: 12px;">
                    <time>{new Date(post.publishedAt!).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                  </div>
                  {post.excerpt && <p class="dim">{post.excerpt}</p>}
                  <a href={`/blog/${post.slug}`} style="display: inline-block; margin-top: 12px;">Read more <span>→</span></a>
                </article>
              ))}
            </div>
          ) : (
            <div class="dim" style="margin-top: clamp(30px, 3.4vw, 56px);">
              <p>No posts yet. Check back soon.</p>
            </div>
          )
        }
      </article>

      <div class="nextup">
        <div><span class="mono">Back to</span><h4>Home</h4></div>
        <a class="go" href="/">Go back <span>→</span></a>
      </div>
    </div>
  </section>
</Base>
