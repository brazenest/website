---
/**
 * Base.astro — the site shell / chrome (BUILD.md §4).
 * <head> fonts preserved exactly from source; the tri-zone rail and the header nav are
 * built FROM DATA (ventures + siteMeta). The runtime colour engine (§3e) is loaded once
 * here as a plain client script. Per-venture colour blocks come from the generated
 * token stylesheet — add a venture in the CMS and the chrome gains its colour world.
 */
import '../styles/fonts.css'
import '../styles/engine.css'
import '../styles/venture-tokens.generated.css'
import { venturesByZone, ventureHref, siteMeta, isExternalHref } from '../lib/content'
import ContactModal from '../components/ContactModal.astro'

interface Props {
  title?: string
  /** Initial identity for the document — sets data-zone / data-work on <html>. */
  zone?: 'neutral' | 'engineering' | 'media'
  work?: string
}

const { title = 'Alden Gillespy', zone = 'neutral', work = 'house' } = Astro.props
const rail = venturesByZone()
const zones = [
  { z: 'neutral', items: rail.neutral },
  { z: 'engineering', items: rail.engineering },
  { z: 'media', items: rail.media },
] as const
---

<!DOCTYPE html>
<html lang="en" data-mode="light" data-zone={zone} data-work={work}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script is:inline>
      // Resolve the colour theme before first paint (no flash). Precedence:
      //   1. a stored user choice, but only if within 7 days of last interaction
      //      (the timestamp is refreshed on every visit — so it expires 7 days after
      //      the last time the site was used, then falls back to system);
      //   2. otherwise the OS prefers-color-scheme.
      try {
        var KEY = 'ag-mode',
          MAXAGE = 6048e5, // 7 days in ms
          now = Date.now(),
          mode = null,
          raw = localStorage.getItem(KEY)
        if (raw) {
          var o = JSON.parse(raw)
          if (o && (o.mode === 'light' || o.mode === 'dark') && now - (+o.ts || 0) <= MAXAGE) {
            mode = o.mode
            localStorage.setItem(KEY, JSON.stringify({ mode: mode, ts: now })) // reset the 7-day clock
          } else {
            localStorage.removeItem(KEY)
          }
        }
        if (!mode) mode = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        document.documentElement.setAttribute('data-mode', mode)
      } catch (e) {}
    </script>
    <script is:inline>
      // Swallow the benign "Transition was skipped" AbortError that a cross-document view
      // transition emits when the browser skips it (fast nav / bg tab) — it falls back to
      // an instant navigation, so it's noise, not a failure.
      addEventListener('unhandledrejection', function (e) {
        if (e.reason && e.reason.name === 'AbortError' && /transition/i.test(e.reason.message || '')) e.preventDefault()
      })
    </script>
    <script is:inline>
      // Entrance choreography, decided before the body paints (motion allowed only):
      //  - .anim plays the reveal "swipe" on EVERY page load (hides [data-reveal] until the
      //    reveal script fades them up). This is the signature motion — always on.
      //  - .page-enter additionally fades the whole page in on a NAVIGATION in browsers
      //    without native cross-document view transitions (Firefox), simulating the page
      //    transition. Chromium uses the native @view-transition cross-fade instead.
      try {
        if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
          var d = document.documentElement
          d.classList.add('anim')
          // Failsafe: if the reveal module never initializes, un-hide everything.
          setTimeout(function () {
            if (!window.__revealReady) d.classList.remove('anim')
          }, 4000)
          var hasNativeVT = false
          try {
            hasNativeVT = window.CSS && CSS.supports('view-transition-name', 'none')
          } catch (e) {}
          if (sessionStorage.getItem('ag-entered') && !hasNativeVT) d.classList.add('page-enter')
        }
        sessionStorage.setItem('ag-entered', '1')
      } catch (e) {}
    </script>
    {/* Self-hosted fonts (see fonts.css). Preload the above-the-fold faces so they're ready
        at first paint — body (Schibsted), the neutral display headline (Cabinet Grotesk 900)
        and the mono kicker (Spline Sans Mono). The rest load from the inlined @font-face as
        each page needs them. crossorigin is required on font preloads even same-origin. */}
    <link rel="preload" as="font" type="font/woff2" href="/fonts/schibsted-grotesk.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/cabinet-grotesk-900.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/spline-sans-mono.woff2" crossorigin />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>

    <!-- THE SPINE: the rail, grouped into three zones — built from the ventures collection. -->
    <nav class="rail" id="rail" aria-label="Portfolio">
      {
        zones.map((group) => (
          <div class="rgroup" data-z={group.z}>
            {group.items.map((v) => (
              <a
                href={ventureHref(v.slug)}
                data-w={v.slug}
                data-name={v.name}
                style={`--seg:${v.palette.key}`}
              />
            ))}
          </div>
        ))
      }
    </nav>

    <header class="top">
      <div class="top__in">
        <a class="wordmark" href="/"><i></i> Alden Gillespy</a>
        <nav class="menu">
          {
            siteMeta.nav.map((item) => {
              const external = isExternalHref(item.href)
              return (
                <a
                  href={item.href}
                  data-route={external || item.href.includes('#') ? undefined : item.href}
                  target={external ? '_blank' : undefined}
                  rel={external ? 'noopener noreferrer' : undefined}
                >
                  {item.label}
                </a>
              )
            })
          }
        </nav>
        <button class="tmode" id="mode" aria-label="Switch colour mode">
          <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1111.2 3a7 7 0 009.8 9.8z"/></svg>
        </button>
        <a class="hire" href="/contact" data-contact-open>Hire me <span>→</span></a>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <!-- FOOTER — global chrome (source lines 1078-1090), missed in the step 4 port; the mini
         swatch groups are generated from the ventures collection, mirroring the rail. -->
    <footer class="foot">
      <div class="col">
        <div><span class="num">© {new Date().getFullYear()}</span> &nbsp;Alden Gillespy · Radiant Ventures</div>
        <div class="mini" aria-hidden="true">
          {
            zones.map((group) => (
              <b>
                {group.items.map((v) => <i style={`--s:${v.palette.key}`} />)}
              </b>
            ))
          }
        </div>
        <div class="links">
          <a href="/contact" data-contact-open>Contact</a>
          {
            siteMeta.social.map((s) => (
              <a
                href={s.url}
                target={isExternalHref(s.url) ? '_blank' : undefined}
                rel={isExternalHref(s.url) ? 'noopener noreferrer' : undefined}
              >
                {s.label}
              </a>
            ))
          }
        </div>
      </div>
    </footer>

    <ContactModal />

    <script>
      import { initEngine } from '../scripts/engine.ts'
      import { initReveal } from '../scripts/reveal.ts'
      // initReveal must run even if the colour engine throws, or [data-reveal]
      // content (hidden by the .anim gate) would be stranded invisible.
      try {
        initEngine()
      } catch (e) {
        console.error(e)
      }
      initReveal()
    </script>
  </body>
</html>
