---
/**
 * YouTube facade (BUILD.md §5). Video is YouTube-only; never self-hosted. Renders a
 * lightweight poster + play button and swaps in the real <iframe> only on click, keeping
 * the film page's Lighthouse score intact. When no youtubeId is set yet (§8.3 — Fault
 * Lines isn't shot/uploaded), falls back to the source's inert "▶ Watch the film" anchor
 * rather than pretending a video exists.
 */
interface Props {
  youtubeId: string | null
  title: string
}

const { youtubeId, title } = Astro.props
---

{
  youtubeId ? (
    <button class="yt-facade" data-yt-id={youtubeId} aria-label={`Play ${title}`}>
      <img
        src={`https://i.ytimg.com/vi/${youtubeId}/maxresdefault.jpg`}
        alt=""
        loading="lazy"
        onerror={`this.onerror=null;this.src='https://i.ytimg.com/vi/${youtubeId}/hqdefault.jpg'`}
      />
      <span class="yt-facade__play" aria-hidden="true">▶</span>
    </button>
  ) : (
    <a class="go" href="#">▶ Watch the film</a>
  )
}

<style>
  .yt-facade {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 2.39/1;
    padding: 0;
    border: 0;
    background: #000;
    cursor: pointer;
    overflow: hidden;
  }
  .yt-facade img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.86;
  }
  .yt-facade__play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: clamp(28px, 3vw, 44px);
    color: #fff;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.6);
  }
  .yt-facade iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>

<script>
  for (const btn of document.querySelectorAll<HTMLButtonElement>('.yt-facade')) {
    btn.addEventListener(
      'click',
      () => {
        const id = btn.dataset.ytId
        const iframe = document.createElement('iframe')
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture'
        iframe.allowFullscreen = true
        btn.replaceChildren(iframe)
      },
      { once: true },
    )
  }
</script>
