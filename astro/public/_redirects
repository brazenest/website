# ── v5 → v6 URL migration (aldengillespy.com domain cutover) ──────────────────
# Pages that MOVED get a 301 to their v6 home. Truly-gone/private paths — /admin/*
# and /api/* — deliberately have NO rule: they fall through to 404.html (HTTP 404).
# Exact rules first, splats last (Cloudflare matches exacts faster; first match wins).

# Résumé is a PDF now
/resume                                        /resume.pdf            301

# Section rename: production → media
/production                                    /media                 301

# Engineering case studies moved to /engineering/<slug>; three carried over
/engineering/projects/memrey                   /engineering/memrey    301
/engineering/projects/rotavox                  /engineering/rotavox   301
/engineering/projects/andacity-booking-system  /engineering/andacity  301
/engineering/projects                          /engineering           301

# Blog canonicalized to /blog/posts/<slug>. Two older shapes redirect in:
#   /blog/articles/<slug>  — the pre-v6 WordPress-era site (still linked from post bodies)
#   /blog/<slug>           — v6.0.0's own short-lived flat shape
# The two bare exacts must stay ABOVE /blog/:slug, or ":slug" swallows the literal segment
# and sends /blog/posts to /blog/posts/posts.
/blog/articles                                 /blog                  301
/blog/posts                                    /blog                  301
/blog/articles/:slug                           /blog/posts/:slug      301
/blog/:slug                                    /blog/posts/:slug      301

# Retired top-level pages
/work                                          /                      301
/for-hire                                      /contact               301
/for/creators                                  /                      301
/for/professionals                             /                      301
/packages                                      /contact               301
/packages/preview                              /contact               301

# Wildcards last: any remaining old project URL → its section
/production/*                                  /media                 301
/engineering/projects/*                        /engineering           301
