# Cloudflare Pages headers. Static hashed assets + self-hosted fonts are content-stable,
# so cache them hard; everything gets a few conservative security headers (no CSP — the
# site uses inline scripts/styles and the Turnstile widget, and a wrong CSP breaks them).

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
