# ── Dependencies ────────────────────────────────────────────────────────────
/node_modules
node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ── Payload CMS (build-time content authority — local only) ──────────────────
# NEVER commit the database: it holds Payload's auth (admin users, password
# hashes). It is rebuilt locally and never leaves this machine.
payload.db
payload.db-*
.env
.env*.local
# Payload's upload dir. The export step copies whatever the build needs into
# astro/src/assets, which IS committed.
/media

# ── Next.js (the Payload admin runs on Next) ─────────────────────────────────
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# ── Build output ─────────────────────────────────────────────────────────────
# (astro/ and contact-worker/ also carry their own .gitignore for dist/.)
/build
/coverage
.vercel

# ── Cloudflare / Wrangler ────────────────────────────────────────────────────
.wrangler
.dev.vars
!.dev.vars.example

# ── Photo originals — kept locally, never served/deployed ────────────────────
/photo-sources/

# ── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Editor / OS ──────────────────────────────────────────────────────────────
/.idea/*
!/.idea/runConfigurations
.DS_Store
*.pem

# ── Testing (Playwright) ─────────────────────────────────────────────────────
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
