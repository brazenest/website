# Local secrets for `wrangler pages dev` (Cloudflare runtime).
# Copy to `.dev.vars` and fill in real values. `.dev.vars` is gitignored.
#
# NOTE: production values are set with `wrangler pages secret put <NAME>`
# (or in the Cloudflare dashboard), NOT here.

# Public origin of the deployed site (used for CSRF/origin checks on form POSTs).
ORIGIN=http://localhost:8788

# Contact form email delivery through Resend (https://resend.com).
# The FROM domain must be verified in Resend.
RESEND_API_KEY=re_your_api_key
CONTACT_FORM_FROM_EMAIL=no-reply@example.com
CONTACT_FORM_TO_EMAIL=you@example.com
CONTACT_FORM_SUBJECT_PREFIX=Website contact

# Admin (/admin) HTTP Basic auth. Leave unset to make /admin return 503.
ADMIN_BASIC_AUTH_USERNAME=
ADMIN_BASIC_AUTH_PASSWORD=

# Local Postgres for the Hyperdrive binding during `wrangler pages dev`.
# Wrangler reads this env var (export it in your shell, or set it here) to back
# the HYPERDRIVE binding locally. `wrangler pages dev` runs the PREVIEW config,
# so this stands in for the dev database.
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgres://user:password@localhost:5432/dbname
