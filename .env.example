# Copy this file to .env and update values for your deployment environment.

# Public origin URL for SSR, prerendering, and CSRF protection.
# Examples: https://aldengillespy.com, http://localhost:3000
ORIGIN=http://localhost:3000

# Server configuration
PORT=3000
HOST=0.0.0.0

# PostgreSQL connection string for blog content queries.
# Example: postgresql://postgres:postgres@localhost:5432/website
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/website

# Optional PostgreSQL SSL behavior.
# PGSSLMODE=require
# PGSSLREJECTUNAUTHORIZED=true

# Server-side HTTP Basic Auth for private /admin routes.
# Keep these values out of client-side env vars and do not commit real secrets.
ADMIN_BASIC_AUTH_USERNAME=admin
ADMIN_BASIC_AUTH_PASSWORD=change-me

# Contact form delivery through Amazon SES.
AWS_REGION=us-east-1
CONTACT_FORM_FROM_EMAIL=no-reply@example.com
CONTACT_FORM_TO_EMAIL=you@example.com
CONTACT_FORM_SUBJECT_PREFIX=Alden Gillespy Website

# AWS credentials are usually supplied by your hosting environment, AWS profile,
# task role, or deployment secret manager rather than a committed file.
# For local testing only, you can also provide:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
