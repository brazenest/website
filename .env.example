# Local environment example
# Copy to .env.development or .env.production and replace placeholder values.

# Public origin used by server-side rendering and request validation.
ORIGIN=http://localhost:3000

# Contact form email delivery through Resend (https://resend.com).
# Create an API key in the Resend dashboard. The FROM address's domain must be
# verified in Resend. CONTACT_FORM_TO_EMAIL may be a comma-separated list.
RESEND_API_KEY=re_your_api_key
CONTACT_FORM_FROM_EMAIL=no-reply@example.com
CONTACT_FORM_TO_EMAIL=you@example.com
CONTACT_FORM_SUBJECT_PREFIX=Website contact

# Local server defaults. The EC2 deploy script passes these explicitly in production.
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
