# Server configuration
ORIGIN=http://localhost:4173
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Database configuration
DATABASE_URL=postgresql://user:password@host:port/database

# Optional PostgreSQL SSL behavior
# PGSSLMODE=require
# PGSSLREJECTUNAUTHORIZED=true

# Private admin access
ADMIN_BASIC_AUTH_USERNAME=admin
ADMIN_BASIC_AUTH_PASSWORD=change-me

# Contact form email delivery via Amazon SES
AWS_REGION=us-east-1
CONTACT_FORM_FROM_EMAIL=no-reply@example.com
CONTACT_FORM_TO_EMAIL=you@example.com
CONTACT_FORM_SUBJECT_PREFIX=Alden Gillespy Website

# AWS credentials are usually supplied by your hosting environment, AWS profile,
# task role, or deployment secret manager rather than committed into a local file.
# For local testing only, you can also provide:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=# Production Environment Configuration
# Copy this file to .env and update values for your deployment environment

# The public origin URL for the application (required for CSRF protection)
# Examples: https://alden.dev, http://localhost:3000
ORIGIN=http://localhost:3000

# PostgreSQL connection string for server-side blog content queries
# Example: postgresql://postgres:postgres@localhost:5432/website
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/website

# Server-side HTTP Basic Auth for private /admin routes
# Keep these values out of client-side env vars and do not commit real secrets
ADMIN_BASIC_AUTH_USERNAME=admin
ADMIN_BASIC_AUTH_PASSWORD=change-me

# Server port to listen on
# Default: 3000
PORT=3000

# Server host to bind to
# Default: 0.0.0.0 (all interfaces)
HOST=0.0.0.0

# Node environment
# Options: development, preview, production
# Default: production
NODE_ENV=production
