---
/**
 * STEP 3 PROOF PAGE (BUILD.md §9.3) — "prove the engine reads from data".
 *
 * Every swatch below is rendered from src/data/ventures.json (exported from the Payload
 * `ventures` collection). Hovering one sets data-work / data-zone on <html>, and the whole
 * chrome — rail, wordmark square, CTA, links, selection — retints via the GENERATED token
 * stylesheet and the html{transition} in engine.css. Nothing here is hardcoded per venture:
 * add a venture in the CMS, run `pnpm run export`, and a new swatch + colour world appears.
 *
 * This is scaffolding, not the final home page (that's step 4). It exists to validate the
 * data→engine contract before any page content is ported.
 */
import Base from '../layouts/Base.astro'
import { ventures } from '../lib/content'
---

<Base title="Engine proof — Alden Gillespy" zone="neutral" work="house">
  <section class="hero z-neutral" data-zone="neutral" data-work="house">
    <div class="col">
      <p class="mono">BUILD.md §9.3 · data → engine proof</p>
      <h1 style="margin-top:18px">The colour is data.</h1>
      <p class="lead">
        Each swatch is one row of <code>ventures.json</code>, exported from the Payload CMS. Hover
        one and the whole site adopts that venture's colour — rail, wordmark, the “Hire me” button,
        links, selection. No colour is hardcoded per venture; the engine's blocks are generated from
        the collection.
      </p>

      <div class="proofgrid" role="list">
        {
          ventures.map((v) => (
            <button
              class="vsw"
              role="listitem"
              data-w={v.slug}
              data-z={v.zone}
              style={`--k:${v.palette.key};--hi:${v.palette.hi};--deep:${v.palette.deep};--lift:${v.palette.lift};--on:${v.palette.on}`}
              aria-label={`Retint site with ${v.name}`}
            >
              <span class="vsw__key" />
              <span class="vsw__body">
                <span class="vsw__name">
                  {v.name}
                  {v.proposed && <span class="vsw__flag">proposed</span>}
                </span>
                <span class="vsw__meta">{v.zone} · {v.palette.key}</span>
                <span class="vsw__ramp">
                  <i style={`background:${v.palette.key}`} />
                  <i style={`background:${v.palette.hi}`} />
                  <i style={`background:${v.palette.deep}`} />
                  <i style={`background:${v.palette.lift}`} />
                </span>
              </span>
            </button>
          ))
        }
      </div>

      <p class="mono proofcount">{ventures.length} ventures loaded from data · reset by moving the mouse away</p>
    </div>
  </section>
</Base>

<style>
  .proofgrid {
    margin-top: clamp(28px, 3vw, 48px);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 14px;
  }
  .vsw {
    display: flex;
    align-items: stretch;
    gap: 0;
    text-align: left;
    border: 1px solid var(--line);
    background: var(--card);
    overflow: hidden;
    transition: border-color 160ms var(--ease), transform 160ms var(--ease);
  }
  .vsw:hover,
  .vsw:focus-visible {
    border-color: var(--k);
    transform: translateY(-2px);
  }
  .vsw__key {
    flex: none;
    width: 46px;
    background: var(--k);
  }
  .vsw__body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 14px 16px;
  }
  .vsw__name {
    font-family: var(--f-d-neutral);
    font-weight: 900;
    letter-spacing: -0.02em;
    font-size: 18px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .vsw__flag {
    font-family: var(--f-m);
    font-weight: 600;
    font-size: 8.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 2px 6px;
    color: var(--k);
    box-shadow: inset 0 0 0 1px currentColor;
  }
  .vsw__meta {
    font-family: var(--f-m);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .vsw__ramp {
    display: flex;
    height: 10px;
    margin-top: 4px;
  }
  .vsw__ramp i {
    flex: 1;
    display: block;
  }
  .proofcount {
    margin-top: 22px;
  }
  code {
    font-family: var(--f-m);
    font-size: 0.85em;
    background: var(--card);
    padding: 1px 6px;
  }
</style>

<script>
  // §3e: the runtime engine stays a small plain client script (no framework island).
  // Here it only does the hover-to-retint that proves the data→engine wiring.
  const root = document.documentElement
  const initialWork = root.dataset.work
  const initialZone = root.dataset.zone

  for (const btn of document.querySelectorAll<HTMLElement>('.vsw')) {
    const retint = () => {
      root.dataset.work = btn.dataset.w ?? 'house'
      root.dataset.zone = btn.dataset.z ?? 'neutral'
    }
    const reset = () => {
      root.dataset.work = initialWork ?? 'house'
      root.dataset.zone = initialZone ?? 'neutral'
    }
    btn.addEventListener('mouseenter', retint)
    btn.addEventListener('focus', retint)
    btn.addEventListener('mouseleave', reset)
    btn.addEventListener('blur', reset)
  }
</script>
