---
/**
 * CONTACT (BUILD.md §7 — deferred design pass). Minimal stub.
 * Renders in the house/neutral identity with a form skeleton. Submission handler is TODO.
 */
import Base from '../layouts/Base.astro'
import { siteMeta } from '../lib/content'
---

<Base title="Contact — Alden Gillespy" zone="neutral" work="house">
  <section class="z-neutral" data-zone="neutral" data-work="house">
    <div class="col">
      <div class="crumb"><span>Contact</span></div>
      <article style="margin-block: clamp(30px, 3.4vw, 56px); max-width: 70ch;">
        <h1 class="halo">Get in touch</h1>
        <p class="dim" style="margin-top: clamp(20px, 2vw, 32px);">
          I build products from the ground up — engineering, design, infrastructure, ops. If you have a problem that needs solving or a product that needs shipping, let's talk.
        </p>

        <!-- FORM STUB — §7 TODO: wire to mail handler (Resend was the plan) -->
        <form class="contact__form" style="margin-top: clamp(30px, 3.4vw, 56px);">
          <fieldset style="border: none; padding: 0; margin: 0;">
            <div class="form__field" style="margin-bottom: 20px;">
              <label for="name" style="display: block; font-size: 13px; font-weight: 500; margin-bottom: 8px;">Name</label>
              <input id="name" type="text" name="name" required style="width: 100%; padding: 12px; font-family: inherit; font-size: 14px; border: 1px solid var(--line); background: var(--paper); color: var(--ink);" />
            </div>
            <div class="form__field" style="margin-bottom: 20px;">
              <label for="email" style="display: block; font-size: 13px; font-weight: 500; margin-bottom: 8px;">Email</label>
              <input id="email" type="email" name="email" required style="width: 100%; padding: 12px; font-family: inherit; font-size: 14px; border: 1px solid var(--line); background: var(--paper); color: var(--ink);" />
            </div>
            <div class="form__field" style="margin-bottom: 20px;">
              <label for="message" style="display: block; font-size: 13px; font-weight: 500; margin-bottom: 8px;">Message</label>
              <textarea id="message" name="message" rows="6" required style="width: 100%; padding: 12px; font-family: inherit; font-size: 14px; border: 1px solid var(--line); background: var(--paper); color: var(--ink); resize: vertical;" />
            </div>
            <button type="submit" style="padding: 12px 20px; background: var(--w-key); color: var(--w-on); border: none; font-weight: 500; cursor: pointer;">Send message</button>
            <p style="margin-top: 12px; font-size: 12px; color: var(--muted);">
              <strong>TODO: form handler</strong> — This form does not yet submit. Will be wired to Resend or equivalent.
            </p>
          </fieldset>
        </form>

        <div style="margin-top: clamp(30px, 3.4vw, 56px); padding-top: clamp(30px, 3.4vw, 56px); border-top: 1px solid var(--line);">
          <p class="dim" style="font-size: 13px; margin-bottom: 12px;">Or reach out directly:</p>
          <div class="contact__row">
            <a class="big" href={`mailto:${siteMeta.contactEmail}`}>{siteMeta.contactEmail} <span>→</span></a>
            {siteMeta.social.map((s) => <a class="alt" href={s.url}>{s.label}</a>)}
          </div>
        </div>
      </article>

      <div class="nextup">
        <div><span class="mono">Back to</span><h4>Home</h4></div>
        <a class="go" href="/">Go back <span>→</span></a>
      </div>
    </div>
  </section>
</Base>
