    "decisions": [
      {
        "question": "Why not just embed everything and search the vectors?",
        "answer": {
          "root": {
            "type": "root",
            "format": "",
            "indent": 0,
            "version": 1,
            "direction": "ltr",
            "children": [
              {
                "type": "paragraph",
                "format": "",
                "indent": 0,
                "version": 1,
                "direction": "ltr",
                "children": [
                  {
                    "type": "text",
                    "format": 0,
                    "style": "",
                    "mode": "normal",
                    "detail": 0,
                    "version": 1,
                    "text": "Because embeddings return photos that look like what you asked for. A memory isn't a similarity, it's a relationship. Vectors find you a beach. The graph finds you that beach, with those people, on that day."
                  }
                ]
              }
            ]
          }
        }
      },
      {
        "question": "Why not a dedicated graph database?",
        "answer": {
          "root": {
            "type": "root",
            "format": "",
            "indent": 0,
            "version": 1,
            "direction": "ltr",
            "children": [
              {
                "type": "paragraph",
                "format": "",
                "indent": 0,
                "version": 1,
                "direction": "ltr",
                "children": [
                  {
                    "type": "text",
                    "format": 0,
                    "style": "",
                    "mode": "normal",
                    "detail": 0,
                    "version": 1,
                    "text": "Because one engineer cannot operate two databases. Postgres with pgvector holds the graph and the vectors in one place, with one backup and one failure mode. The right architecture is the one you can still run at 2am."
                  }
                ]
              }
            ]
          }
        }
      },
      {
        "question": "Why not fine-tune a model on the corpus?",
        "answer": {
          "root": {
            "type": "root",
            "format": "",
            "indent": 0,
            "version": 1,
            "direction": "ltr",
            "children": [
              {
                "type": "paragraph",
                "format": "",
                "indent": 0,
                "version": 1,
                "direction": "ltr",
                "children": [
                  {
                    "type": "text",
                    "format": 0,
                    "style": "",
                    "mode": "normal",
                    "detail": 0,
                    "version": 1,
                    "text": "Because a family archive is thirty thousand photographs, not thirty million. There is nothing in it CLIP doesn't already know. The value was never in the model — it's in the graph I built around it."
                  }
                ]
              }
            ]
          }
        }
      }
